# ─── Data & Outputs (never commit raw or reduced data) ───────────────────────
data/
output/
outputs/
*.fits
*.fit
*.fts
*.FITS

# ─── Jupyter Notebooks (outputs only — track the notebooks themselves) ────────
notebooks/.ipynb_checkpoints/
**/.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.whl
MANIFEST

# ─── Virtual environments ────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ─── IDEs & editors ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

