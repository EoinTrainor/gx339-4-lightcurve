\@writefile{lof}{\contentsline {figure}{\numberline {26}{\ignorespaces Raw ZOGY matched-filter statistic $S_\mathrm  {target}$ vs MJD for all 234 good frames, coloured by OB. Dashed horizontal lines show the per-OB mean. The large OB-to-OB variation (means spanning $-4\times 10^8$ to $+1.3\times 10^9$ units) reflects variable accretion activity across the 66.8-day campaign; this long-term trend must be removed before phase-folding.}}{23}{figure.26}\protected@file@percent }
\newlabel{fig:lc_raw}{{26}{23}{Raw ZOGY matched-filter statistic $S_\mathrm {target}$ vs MJD for all 234 good frames, coloured by OB. Dashed horizontal lines show the per-OB mean. The large OB-to-OB variation (means spanning $-4\times 10^8$ to $+1.3\times 10^9$ units) reflects variable accretion activity across the 66.8-day campaign; this long-term trend must be removed before phase-folding}{figure.26}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {27}{\ignorespaces ZOGY $S$ statistic for 8 non-variable reference stars ($K_s = 9.5$--$11.7$\,mag) vs MJD. Non-variable sources should produce $S \approx 0$ in all frames; the observed OB-to-OB scatter (amplitude $\sim 10^9$ units) matches that of the GX~339-4 target, confirming the noise is dominated by PSF-matching systematics common to all sources in the field, not by astrophysical variability in the target itself.}}{23}{figure.27}\protected@file@percent }
\newlabel{fig:ref_stars}{{27}{23}{ZOGY $S$ statistic for 8 non-variable reference stars ($K_s = 9.5$--$11.7$\,mag) vs MJD. Non-variable sources should produce $S \approx 0$ in all frames; the observed OB-to-OB scatter (amplitude $\sim 10^9$ units) matches that of the GX~339-4 target, confirming the noise is dominated by PSF-matching systematics common to all sources in the field, not by astrophysical variability in the target itself}{figure.27}{}}
