\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Swift BAT 15--50\,keV daily lightcurve of GX~339-4 (red points) over the 2025 campaign window, with ESO HAWK-I observing block windows marked as dashed vertical lines (OB numbers labelled at the top). The $\pm 1\sigma $ and $\pm 3\sigma $ quiescence bands are shown as dotted lines. OB\,5 (MJD\,$\approx 60855$) coincides with a prominent X-ray flare; OBs~10--12 fall after the outburst onset near MJD\,$\approx 60900$.}}{10}{figure.11}\protected@file@percent }
\newlabel{fig:bat_obs}{{11}{10}{Swift BAT 15--50\,keV daily lightcurve of GX~339-4 (red points) over the 2025 campaign window, with ESO HAWK-I observing block windows marked as dashed vertical lines (OB numbers labelled at the top). The $\pm 1\sigma $ and $\pm 3\sigma $ quiescence bands are shown as dotted lines. OB\,5 (MJD\,$\approx 60855$) coincides with a prominent X-ray flare; OBs~10--12 fall after the outburst onset near MJD\,$\approx 60900$}{figure.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces As Fig.~\ref {fig:bat_obs}, with the quiescence baseline ($\mu _q$, blue solid line) and $+3\sigma $ outburst threshold (blue dashed) derived from high-side sigma-clipping of the full BAT history. Points flagged as $\geq 3\sigma $ outburst detections are highlighted in orange. OBs~10--12 land firmly above the outburst threshold.}}{11}{figure.12}\protected@file@percent }
\newlabel{fig:bat_sigma}{{12}{11}{As Fig.~\ref {fig:bat_obs}, with the quiescence baseline ($\mu _q$, blue solid line) and $+3\sigma $ outburst threshold (blue dashed) derived from high-side sigma-clipping of the full BAT history. Points flagged as $\geq 3\sigma $ outburst detections are highlighted in orange. OBs~10--12 land firmly above the outburst threshold}{figure.12}{}}
