\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces HAWK-I Ks-band reference field of GX~339-4, built from the inverse-variance co-addition of all 236 science frames. \textit  {Left:} full chip\,1 ($2048\times 2048$\,px, $\sim \!3.6'\times 3.6'$); the cyan box marks the $\pm 90$\,px region around the target. \textit  {Right:} $\pm 80$\,px ($8.5''$) zoom; GX~339-4 is circled in cyan. The field is severely crowded, with several sources within one PSF FWHM of the target. Scale bars: $1'$ (left) and $5''$ (right).}}{4}{figure.1}\protected@file@percent }
\newlabel{fig:finding_chart}{{1}{4}{HAWK-I Ks-band reference field of GX~339-4, built from the inverse-variance co-addition of all 236 science frames. \textit {Left:} full chip\,1 ($2048\times 2048$\,px, $\sim \!3.6'\times 3.6'$); the cyan box marks the $\pm 90$\,px region around the target. \textit {Right:} $\pm 80$\,px ($8.5''$) zoom; GX~339-4 is circled in cyan. The field is severely crowded, with several sources within one PSF FWHM of the target. Scale bars: $1'$ (left) and $5''$ (right)}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Mean Ks-band sky background level per OB. Error bars show the frame-to-frame standard deviation within each OB. Sky levels vary between $\sim \!10\,500$\,ADU (OB\,4, 2025-06-19) and $\sim \!18\,000$\,ADU (OB\,11, 2025-09-19) across the campaign, reflecting lunar phase and seasonal sky brightness changes.}}{4}{figure.2}\protected@file@percent }
\newlabel{fig:sky_mean}{{2}{4}{Mean Ks-band sky background level per OB. Error bars show the frame-to-frame standard deviation within each OB. Sky levels vary between $\sim \!10\,500$\,ADU (OB\,4, 2025-06-19) and $\sim \!18\,000$\,ADU (OB\,11, 2025-09-19) across the campaign, reflecting lunar phase and seasonal sky brightness changes}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Frame-to-frame sky variability (standard deviation of per-frame sky medians) within each OB. Most OBs show stable sky conditions ($\sigma _\mathrm  {sky} \lesssim 200$\,ADU). OB\,9 (2025-07-23) is a clear outlier at $\sigma \approx 600$\,ADU, indicating variable transparency that night; this is also visible in the residuals plot (Fig.~\ref {fig:calib_residuals}).}}{5}{figure.3}\protected@file@percent }
\newlabel{fig:sky_std}{{3}{5}{Frame-to-frame sky variability (standard deviation of per-frame sky medians) within each OB. Most OBs show stable sky conditions ($\sigma _\mathrm {sky} \lesssim 200$\,ADU). OB\,9 (2025-07-23) is a clear outlier at $\sigma \approx 600$\,ADU, indicating variable transparency that night; this is also visible in the residuals plot (Fig.~\ref {fig:calib_residuals})}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Per-frame post-sky-subtraction residuals for all 12 OBs. Each dot is one science frame; the horizontal bar is the OB mean. Residuals are centred on zero for OBs~1--11, confirming that sky subtraction is unbiased. OB~9 (2025-07-23) shows elevated scatter, likely driven by variable sky transparency that night.}}{5}{figure.4}\protected@file@percent }
\newlabel{fig:calib_residuals}{{4}{5}{Per-frame post-sky-subtraction residuals for all 12 OBs. Each dot is one science frame; the horizontal bar is the OB mean. Residuals are centred on zero for OBs~1--11, confirming that sky subtraction is unbiased. OB~9 (2025-07-23) shows elevated scatter, likely driven by variable sky transparency that night}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Ks-band cutout of GX~339-4 (OB\,1, 2025-05-17) with the circular aperture ($r = 6$\,px, inner ring) and sky annulus ($r = 10$--$16$\,px, outer rings) overlaid. A bright neighbour is visible to the upper right; its halo falls within the outer annulus, biasing the sky estimate and contaminating the net flux measurement. The proximity of this neighbour means the net flux cannot be cleanly attributed to GX~339-4 alone.}}{6}{figure.5}\protected@file@percent }
\newlabel{fig:ap_cutout}{{5}{6}{Ks-band cutout of GX~339-4 (OB\,1, 2025-05-17) with the circular aperture ($r = 6$\,px, inner ring) and sky annulus ($r = 10$--$16$\,px, outer rings) overlaid. A bright neighbour is visible to the upper right; its halo falls within the outer annulus, biasing the sky estimate and contaminating the net flux measurement. The proximity of this neighbour means the net flux cannot be cleanly attributed to GX~339-4 alone}{figure.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.2}Results}{6}{subsection.2.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Annulus pixel-value distributions for OB\,1 (left, quiescent, 2025-05-17) and OB\,11 (right, outburst, 2025-08-14). Grey bars show all raw annulus pixels; orange bars show the sigma-clipped (retained) subset. The dashed vertical line is the iterative clip threshold; the solid line marks the final background median $B$; dotted lines show $B \pm \sigma _B$. In OB\,1 the annulus is uncontaminated: the raw and retained distributions are nearly identical and $B$ is well-defined. In OB\,11 a low-value tail from PSF wings of the saturating GX~339-4 source extends into the inner annulus edge; the sigma-clip masks these pixels, pulling $B$ toward the true sky level and preventing an overestimated background.}}{7}{figure.6}\protected@file@percent }
\newlabel{fig:annulus_hist}{{6}{7}{Annulus pixel-value distributions for OB\,1 (left, quiescent, 2025-05-17) and OB\,11 (right, outburst, 2025-08-14). Grey bars show all raw annulus pixels; orange bars show the sigma-clipped (retained) subset. The dashed vertical line is the iterative clip threshold; the solid line marks the final background median $B$; dotted lines show $B \pm \sigma _B$. In OB\,1 the annulus is uncontaminated: the raw and retained distributions are nearly identical and $B$ is well-defined. In OB\,11 a low-value tail from PSF wings of the saturating GX~339-4 source extends into the inner annulus edge; the sigma-clip masks these pixels, pulling $B$ toward the true sky level and preventing an overestimated background}{figure.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.3}Interpretation}{7}{subsection.2.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Differential Ks-band magnitude of GX~339-4 relative to comparison Star~3 ($K_s \approx 14.5$\,mag) across all 13 per-OB co-adds. OBs~1--9 (May--Jul 2025) cluster near $\Delta m \approx 3.3$--$3.6$, placing GX~339-4 at $K_s \approx 17$--$18$\,mag. OBs~10--12 (Aug--Sep 2025) drop to $\Delta m \approx -0.5$--$+0.1$, indicating GX~339-4 has brightened to near the comparison star flux during outburst.}}{8}{figure.7}\protected@file@percent }
\newlabel{fig:gx_vs_star3}{{7}{8}{Differential Ks-band magnitude of GX~339-4 relative to comparison Star~3 ($K_s \approx 14.5$\,mag) across all 13 per-OB co-adds. OBs~1--9 (May--Jul 2025) cluster near $\Delta m \approx 3.3$--$3.6$, placing GX~339-4 at $K_s \approx 17$--$18$\,mag. OBs~10--12 (Aug--Sep 2025) drop to $\Delta m \approx -0.5$--$+0.1$, indicating GX~339-4 has brightened to near the comparison star flux during outburst}{figure.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Ks-band cutouts with aperture ($r = 6$\,px, inner ring) and sky annulus ($r = 10$--$16$\,px, outer rings) overlaid, illustrating two distinct contamination regimes. \textit  {Left}: OB\,3 (2025-06-04, quiescent). Two bright field stars are clearly resolved within the annulus region -- upper-right and lower-right of centre -- whose elevated pixels would bias $B$ upward without sigma-clip masking. \textit  {Right}: OB\,11 (2025-08-14, outburst). GX~339-4 is saturating and its extended PSF wings spill into the inner annulus; the sigma-clip masks the resulting high-flux tail, preventing the sky level from being overestimated. In both cases the final background $B$ is estimated from the unmasked (orange) pixel subset shown in Figure~\ref {fig:annulus_hist}.}}{8}{figure.8}\protected@file@percent }
\newlabel{fig:annulus_cutouts}{{8}{8}{Ks-band cutouts with aperture ($r = 6$\,px, inner ring) and sky annulus ($r = 10$--$16$\,px, outer rings) overlaid, illustrating two distinct contamination regimes. \textit {Left}: OB\,3 (2025-06-04, quiescent). Two bright field stars are clearly resolved within the annulus region -- upper-right and lower-right of centre -- whose elevated pixels would bias $B$ upward without sigma-clip masking. \textit {Right}: OB\,11 (2025-08-14, outburst). GX~339-4 is saturating and its extended PSF wings spill into the inner annulus; the sigma-clip masks the resulting high-flux tail, preventing the sky level from being overestimated. In both cases the final background $B$ is estimated from the unmasked (orange) pixel subset shown in Figure~\ref {fig:annulus_hist}}{figure.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces GX~339-4 aperture and sky annulus with the pixel mask overlaid. The yellow circle marks the source aperture; the two cyan circles bound the sky annulus ($r = 10$--$16$\,px). The green region shows the \textit  {unmasked} (retained) annulus pixels that contribute to the sky estimate. The asymmetric exclusion of pixels in the lower portion of the annulus is caused by the halo of the bright neighbour (upper left) bleeding into the annulus; the sigma-clip procedure identifies these elevated pixels and removes them, preventing the sky level from being biased high.}}{9}{figure.9}\protected@file@percent }
\newlabel{fig:annulus_overlay}{{9}{9}{GX~339-4 aperture and sky annulus with the pixel mask overlaid. The yellow circle marks the source aperture; the two cyan circles bound the sky annulus ($r = 10$--$16$\,px). The green region shows the \textit {unmasked} (retained) annulus pixels that contribute to the sky estimate. The asymmetric exclusion of pixels in the lower portion of the annulus is caused by the halo of the bright neighbour (upper left) bleeding into the annulus; the sigma-clip procedure identifies these elevated pixels and removes them, preventing the sky level from being biased high}{figure.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces GX~339-4 net Ks-band flux vs MJD for all 13 per-OB co-adds ($r = 6$\,px aperture, sigma-clipped sky background). OBs~1--10 (blue circles, May--Jul 2025) show a quiescent baseline of $\sim $20\,000--60\,000\,ADU with a gradual upward trend. OBs~11--13 (red stars, Aug--Sep 2025) jump by a factor of $\sim $20--30 to $>900\,000$\,ADU, marking the onset of a hard X-ray outburst confirmed by Swift BAT (Section~\ref {sec:bat}). Error bars are $1\sigma $ (flux/SNR).}}{9}{figure.10}\protected@file@percent }
\newlabel{fig:lc_13ob}{{10}{9}{GX~339-4 net Ks-band flux vs MJD for all 13 per-OB co-adds ($r = 6$\,px aperture, sigma-clipped sky background). OBs~1--10 (blue circles, May--Jul 2025) show a quiescent baseline of $\sim $20\,000--60\,000\,ADU with a gradual upward trend. OBs~11--13 (red stars, Aug--Sep 2025) jump by a factor of $\sim $20--30 to $>900\,000$\,ADU, marking the onset of a hard X-ray outburst confirmed by Swift BAT (Section~\ref {sec:bat}). Error bars are $1\sigma $ (flux/SNR)}{figure.10}{}}
